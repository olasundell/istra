# Host port for the loopback-only Docker Compose deployment.
ISTRA_PORT=4317

# Host port for PostgreSQL. Port 5433 avoids the common local 5432 collision.
ISTRA_POSTGRES_PORT=5433
POSTGRES_DB=istra
POSTGRES_USER=istra
POSTGRES_PASSWORD=replace-with-a-private-local-password

# Host runtimes can use the same private file during migration and CI. Keep the
# password here in sync with POSTGRES_PASSWORD, percent-encoding it if needed.
ISTRA_STORAGE=postgresql
ISTRA_DATABASE_URL=postgresql://istra:replace-with-a-private-local-password@127.0.0.1:5433/istra

# The application container reaches PostgreSQL over the internal Compose network.
# Keep this password in sync too; percent-encode URL-special characters.
ISTRA_COMPOSE_DATABASE_URL=postgresql://istra:replace-with-a-private-local-password@postgres:5432/istra
ISTRA_POSTGRES_POOL_MAX=4
