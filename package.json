{
  "name": "istra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite",
    "build": "pnpm build:server && pnpm build:web && pnpm build:plugin",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build:plugin": "vite build --config vite.plugin.config.ts",
    "start": "node dist/server.js",
    "migrate": "tsx src/cli/migrate.ts",
    "mcp": "tsx src/adapters/mcp/stdio.ts",
    "mcp:start": "node dist/adapters/mcp/stdio.js",
    "test": "vitest run",
    "test:backend": "vitest run src --exclude 'src/web/**'",
    "test:web": "vitest run src/web",
    "test:plugin": "vitest run src/integration/plugin-package.test.ts src/integration/opencode-plugin.test.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "fastify": "^5.6.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.11.0"
}
